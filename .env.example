NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=https://arf.erkanerdem.net

DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
FIREBASE_SERVICE_ACCOUNT=
ALLOW_UNVERIFIED_AUTH=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional local embedding fallback for research_lab/scripts/ingest_document.mjs
# OpenAI-compatible example: http://127.0.0.1:11434/v1/embeddings
# llama.cpp example: http://127.0.0.1:8080/embedding
LOCAL_EMBEDDING_URL=
LOCAL_EMBEDDING_MODEL=embeddinggemma
LOCAL_EMBEDDING_FORMAT=auto
LOCAL_EMBEDDING_API_KEY=

# RAG local GGUF models
RAG_MODELS_DIR=D:\arf\research_lab\models
RAG_EMBEDDING_MODEL=hf_ggml-org_embeddinggemma-300M-Q8_0
RAG_EMBEDDING_MODEL_PATH=D:\arf\research_lab\models\hf_ggml-org_embeddinggemma-300M-Q8_0.gguf
RAG_EMBEDDING_URL=http://127.0.0.1:8080/v1/embeddings
RAG_EMBEDDING_CMD=node
RAG_EMBEDDING_ARGS=scripts/rag/llama-embedding-wrapper.mjs
RAG_EMBED_DIM=768
RAG_RERANKER_MODEL=hf_ggml-org_qwen3-reranker-0.6b-q8_0
RAG_RERANKER_MODEL_PATH=D:\arf\research_lab\models\hf_ggml-org_qwen3-reranker-0.6b-q8_0.gguf
RAG_QUERY_EXPANSION_MODEL=hf_tobil_qmd-query-expansion-1.7B-q4_k_m
RAG_QUERY_EXPANSION_MODEL_PATH=D:\arf\research_lab\models\hf_tobil_qmd-query-expansion-1.7B-q4_k_m.gguf

# Smoke-test local GGUF embedding before ingestion:
# "test embedding" | node scripts/rag/llama-embedding-wrapper.mjs

# Database (PostgreSQL + pgvector)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=arf_db
DATABASE_URL=postgresql://postgres:change-me@db:5432/arf_db
