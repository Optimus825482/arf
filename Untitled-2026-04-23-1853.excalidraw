    {
      "id": "2SY40BmvXF6wTfWaqEmH-",
      "type": "text",
      "x": 667.2783929733997,
      "y": -465.54133101997195,
      "width": 569,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1572110481,
      "version": 337,
      "versionNonce": 408030591,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776960885080,
      "link": null,
      "locked": false,
      "text": "RÜTBESİ BELİRLENEN MÜRETTEBAT İÇİN \nBİR GENEL DURUM RAPORU HAZIRLANIR VE\nGÖREV GÖZCÜSÜ İLK LOGİN OLDUĞUNDA KENDİSİNE \nSUNULUR VE GÖREV GÖZCÜSÜ PANELINDE \nUYGULANACAK PLAN VE PLANIN ILERLEME ADIMLARI\nREVİZE EDİLDİĞİNDE İSE BUNUDA GÖSTEREREK \nGİDİŞAT GRAFİK VE GÖRSEL DESTEKLİ OLARAK \nSUNULUR",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 193,
      "containerId": null,
      "originalText": "RÜTBESİ BELİRLENEN MÜRETTEBAT İÇİN \nBİR GENEL DURUM RAPORU HAZIRLANIR VE\nGÖREV GÖZCÜSÜ İLK LOGİN OLDUĞUNDA KENDİSİNE \nSUNULUR VE GÖREV GÖZCÜSÜ PANELINDE \nUYGULANACAK PLAN VE PLANIN ILERLEME ADIMLARI\nREVİZE EDİLDİĞİNDE İSE BUNUDA GÖSTEREREK \nGİDİŞAT GRAFİK VE GÖRSEL DESTEKLİ OLARAK \nSUNULUR",
