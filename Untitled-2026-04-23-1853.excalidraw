    {
      "id": "GyxuzpmzX3OBhHS8pmawA",
      "type": "text",
      "x": 71.66863141741078,
      "y": 141.7233564744314,
      "width": 546.4502532958986,
      "height": 163.8531494140626,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1252275839,
      "version": 470,
      "versionNonce": 1622762271,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776960896012,
      "link": null,
      "locked": false,
      "text": "AYRICA GELŞIM PLANLANANADAN HIZLI YADA\nYAVAŞ ILERLIYORSA ILGILI PLAN YAPAY ZEKA \nDESTEĞİ İLE REVİZE EDİLİR ÖDÜLLER RÜTBE ATLAMA VS \nREVİZE EDİLİR. ANA HEDEF GEMİNİN KOMUTANI OLABİLMEK\nOLAN MÜRETTEBATIDA OYUN ESNASINDA BU KONUDA \nMOTİVE EDİCİ MESAJLAR NOTLAR GÖREVLER SONRASI \nTEEBRİK MESAJLARINDA BU NOKTAYA DOĞRU MOTİVASYONLAR\nOLMALI",
      "fontSize": 16.385314941406254,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 157.00000000000009,
      "containerId": null,
      "originalText": "AYRICA GELŞIM PLANLANANADAN HIZLI YADA\nYAVAŞ ILERLIYORSA ILGILI PLAN YAPAY ZEKA \nDESTEĞİ İLE REVİZE EDİLİR ÖDÜLLER RÜTBE ATLAMA VS \nREVİZE EDİLİR. ANA HEDEF GEMİNİN KOMUTANI OLABİLMEK\nOLAN MÜRETTEBATIDA OYUN ESNASINDA BU KONUDA \nMOTİVE EDİCİ MESAJLAR NOTLAR GÖREVLER SONRASI \nTEEBRİK MESAJLARINDA BU NOKTAYA DOĞRU MOTİVASYONLAR\nOLMALI",
      "lineHeight": 1.25
    },
