      "isDeleted": false,
      "boundElements": null,
      "updated": 1776960896012,
      "link": null,
      "locked": false,
      "text": "RÜTBESİ BELİRLENEN\nMÜRETTEBAT IN BİR SONRAKİ\nRÜTBELERE GEÇİŞİ İÇİN \nGEREKLİ PLAN ARKA PLANDA \nYAPAY ZEKA TARAFINDAN HAZIRLANIR",
      "fontSize": 13.598614501953127,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 80,
      "containerId": null,
      "originalText": "RÜTBESİ BELİRLENEN\nMÜRETTEBAT IN BİR SONRAKİ\nRÜTBELERE GEÇİŞİ İÇİN \nGEREKLİ PLAN ARKA PLANDA \nYAPAY ZEKA TARAFINDAN HAZIRLANIR",
      "lineHeight": 1.25
    },
    {
      "id": "6Ab9dDjBboLoU1Dznu-9c",
      "type": "text",
      "x": 163.83669281005837,
      "y": -173.89267135759962,
      "width": 357,
      "height": 67.99307250976564,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1710741695,
      "version": 616,
      "versionNonce": 210184863,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776960896012,
      "link": null,
      "locked": false,
      "text": "BU PLANA MUKABIL GÖREVLER VE GÖREVLERİN\nSONUCUNDA MÜRETTEBATA VERİLECEK PUANLAR \nVE ROZETLER VS GIBI ÖDÜLLER BELİRLENİR VE \nMÜRETTEBATA ÖZEL DOSYAYA KAYDEDİLİR",
      "fontSize": 13.598614501953127,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 63,
      "containerId": null,
      "originalText": "BU PLANA MUKABIL GÖREVLER VE GÖREVLERİN\nSONUCUNDA MÜRETTEBATA VERİLECEK PUANLAR \nVE ROZETLER VS GIBI ÖDÜLLER BELİRLENİR VE \nMÜRETTEBATA ÖZEL DOSYAYA KAYDEDİLİR",
      "lineHeight": 1.25
    },
