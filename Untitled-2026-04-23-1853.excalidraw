    {
      "id": "Oa8CMAk6QEetq0mH-iInN",
      "type": "text",
      "x": 200.3388442993163,
      "y": -58.02411922466081,
      "width": 276.3217163085937,
      "height": 139.71322734704174,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1083193329,
      "version": 554,
      "versionNonce": 1241927391,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776960896012,
      "link": null,
      "locked": false,
      "text": "MÜRETTEBAT GÖREVLERİ \nYAPMADAN ÖNCE GÖREV ÖNCESİ\nBRİFİNGLERDE VE GELİŞİM EĞER \nYAVAŞ İLERLİYORSA KOMUTANDAN GELEN\nANLIK MESAJLARLA MÜRETTABATIN \nDİKKATİ GELİŞTİRMESİ GEREKEN\nKONUYAÇEKİLEREK  BU KONUDA YAPTIĞI \nPRATİKLERLE İLGİLİ ALANI \nGELİŞTİRMESİ AMAÇLANIR",
      "fontSize": 12.41895354195927,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 134.99999999999994,
      "containerId": null,
      "originalText": "MÜRETTEBAT GÖREVLERİ \nYAPMADAN ÖNCE GÖREV ÖNCESİ\nBRİFİNGLERDE VE GELİŞİM EĞER \nYAVAŞ İLERLİYORSA KOMUTANDAN GELEN\nANLIK MESAJLARLA MÜRETTABATIN \nDİKKATİ GELİŞTİRMESİ GEREKEN\nKONUYAÇEKİLEREK  BU KONUDA YAPTIĞI \nPRATİKLERLE İLGİLİ ALANI \nGELİŞTİRMESİ AMAÇLANIR",
      "lineHeight": 1.25
    },
